{
  "name": "@pickleball/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Background worker: video metadata + poster thumbnails (S3/R2)",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@pickleball/db": "workspace:*",
    "@pickleball/suggestions": "workspace:*",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@pickleball/config": "workspace:*",
    "@types/node": "^22.14.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
