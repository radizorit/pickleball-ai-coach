###
### Pickleball Assistant — example environment variables
###
### Copy to .env (root) and fill in. Each app reads from this single file via
### its own zod-validated env loader; do NOT scatter per-app .env files.
###
### Never commit real secrets.
###

# --- General ---
NODE_ENV=development

# --- Web app (apps/web) ---
# Public URL the browser hits the Next.js app at.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL the browser hits the API at.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Optional internal URL the Next.js server uses to reach the API (private
# network, Docker DNS). If unset, falls back to NEXT_PUBLIC_API_URL.
# API_INTERNAL_URL=http://api:4000

# --- Clerk (auth) ---
# Replace REPLACE_ME with keys from https://dashboard.clerk.com → API Keys.
# CI / `next build` without real keys: keep REPLACE_ME — Clerk UI is disabled
# until you paste real keys (see README).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- API (apps/api) ---
PORT=4000
# Comma-separated origins allowed to call the API from the browser.
CORS_ORIGINS=http://localhost:3000

# --- Database (Postgres) ---
DATABASE_URL=postgres://pickleball:pickleball@localhost:5432/pickleball
DATABASE_URL_UNPOOLED=postgres://pickleball:pickleball@localhost:5432/pickleball

# --- API + worker: S3-compatible storage (AWS S3 or Cloudflare R2) ---
# The worker requires S3_* at startup (it reads/writes objects for processing).
# The API needs the same values for presigned uploads + HeadObject checks.
# For AWS: set bucket + IAM access keys + region; leave S3_ENDPOINT unset.
# For R2/MinIO: set S3_ENDPOINT (+ often S3_REGION=auto).
#
# AWS quick start:
# 1) S3 → Create bucket (note region, e.g. us-west-2). Block public access is OK (presigned URLs).
# 2) IAM → user with programmatic access → policy allowing s3:GetObject, PutObject, HeadObject on that bucket.
# 3) Paste values below (uncomment).
#
# S3_BUCKET=my-bucket-name
# S3_REGION=us-west-2
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...
# Leave unset on API only → presign returns 503 (noop). Worker will not start without these four.
#
# Cloudflare R2 example (custom endpoint + auto region):
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
#
# Optional caps:
# MAX_VIDEO_UPLOAD_BYTES=5368709120
# PRESIGNED_UPLOAD_EXPIRES_SECONDS=3600
# Max TTL (seconds) for presigned GET used by `/v1/videos/:id/read-url` (playback + poster).

# --- Worker (apps/worker) ---
# Polls Postgres for videos in `uploaded` (or stale `processing`) and writes metadata + poster.jpg to the same bucket.
# Requires the same S3/R2 credentials as the API plus DATABASE_URL.
# WORKER_POLL_INTERVAL_MS=3000
# WORKER_STALE_PROCESSING_SECONDS=900
# Use full paths if your worker process does not inherit a shell PATH with Homebrew (common in IDEs):
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# FFPROBE_BIN=/opt/homebrew/bin/ffprobe
# Or Intel Homebrew: /usr/local/bin/ffmpeg and /usr/local/bin/ffprobe
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
#
# Suggested-shot heuristics (optional tuning — see README “Suggested shots”):
# SUGGESTION_MIN_CONFIDENCE=0.42
# SUGGESTION_MIN_SPACING_SEC=2.5
# SUGGESTION_MERGE_GAP_SEC=0.45
# SUGGESTION_MAX_COUNT=28
# SUGGESTION_SCENE_THRESHOLD=0.28
# SUGGESTION_MOTION_THRESHOLD=0.18
# SUGGESTION_AUDIO_PEAK_DB=-28
# SUGGESTION_WEIGHT_SCENE=0.35
# SUGGESTION_WEIGHT_AUDIO=0.4
# SUGGESTION_WEIGHT_MOTION=0.25
# SUGGESTION_MAX_SPACING_SEC=45
# SUGGESTION_SCENE_SAMPLE_FPS=8
# SUGGESTION_DEBUG_PIPELINE=1
