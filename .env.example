###
### Pickleball Assistant — example environment variables
###
### Copy to .env (root) and fill in. Each app reads from this single file via
### its own zod-validated env loader; do NOT scatter per-app .env files.
###
### Never commit real secrets.
###

# --- General ---
NODE_ENV=development

# --- Web app (apps/web) ---
# Public URL the browser hits the Next.js app at.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL the browser hits the API at.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Optional internal URL the Next.js server uses to reach the API (private
# network, Docker DNS). If unset, falls back to NEXT_PUBLIC_API_URL.
# API_INTERNAL_URL=http://api:4000

# --- Clerk (auth) ---
# Replace REPLACE_ME with keys from https://dashboard.clerk.com → API Keys.
# CI / `next build` without real keys: keep REPLACE_ME — Clerk UI is disabled
# until you paste real keys (see README).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- API (apps/api) ---
PORT=4000
# Comma-separated origins allowed to call the API from the browser.
CORS_ORIGINS=http://localhost:3000

# --- Database (Postgres) ---
DATABASE_URL=postgres://pickleball:pickleball@localhost:5432/pickleball
DATABASE_URL_UNPOOLED=postgres://pickleball:pickleball@localhost:5432/pickleball

# --- API: S3-compatible uploads (AWS S3 or Cloudflare R2) ---
# When all required fields are set, the API issues presigned PUT URLs for direct browser uploads.
# Leave unset to keep the noop adapter (presign returns 503).
# S3_BUCKET=my-bucket
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# For AWS S3 (default region us-east-1 if no custom endpoint):
# S3_REGION=us-east-1
# For Cloudflare R2 (use account S3 API endpoint + "auto" region):
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# Optional caps:
# MAX_VIDEO_UPLOAD_BYTES=5368709120
# PRESIGNED_UPLOAD_EXPIRES_SECONDS=3600
